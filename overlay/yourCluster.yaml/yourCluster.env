

export OVERLAY_NAME="yourCluster" #The name of this overlay
export CLUSTER_EXTERNAL_DOMAIN="yourCluster.dk" #The external domain for the cluster, used for cert-manager and ingress
export CLUSTER_NAME="${OVERLAY_NAME}"

###############################
#           TALOS            #
###############################


#Use the "Initial Installation" from the image factory
export TALOS_INSTALL_IMAGE="factory.talos.dev/nocloud-installer-secureboot/38671e8d17752b410526f3ebff7e9ce120b84d82316bc411d9352730ab4ab1a0:v1.12.0"
export POD_CIDR="10.30.0.0/16" #These needs to be unique and routable
export SERVICE_CIDR="10.31.0.0/16" #These needs to be unique and routable
export KUBERNETES_VERSION="1.35.0"
export TALOS_VERSION="v1.12.0" #The version of Talos to use

#If true, worker.yaml, controlplane.yaml etc will be overwritten, which is the default
#These configs will be regenerated based on the current settings in this env file
export TALOS_OVERWRITE_CONF=false

#Should only be set to true the first time the cluster is created, or if you want to reset everything
export TALOS_OVERWRITE_SECRETS=false #If true, the secrets file will be overwritten

#If set to true, all talos nodes will be reset, and all of their data will be deleted
#Should only be set to true if you want to completely reset the cluster
export TALOS_RESET_NODES=false

# Control plane nodes array
export TALOS_CONTROL_NODES=("yourCluster-01.yourCluster.dk" "yourCluster-02.yourCluster.dk") #Needs to be resolvable

# Worker nodes array
export TALOS_WORKER_NODES=("yourCluster-03.yourCluster.dk" "yourCluster-04.yourCluster.dk") #Needs to be resolvable

# Total number of nodes (control + worker) - used for Longhorn disk discovery
export TALOS_NR_OF_NODES=$((${#TALOS_CONTROL_NODES[@]} + ${#TALOS_WORKER_NODES[@]}))

# Allow scheduling workloads on control plane nodes
export TALOS_ALLOW_SCHEDULING_ON_CONTROLPLANES=false #If false, control plane nodes will be tainted to prevent workload scheduling

export TALOS_CLUSTER_NAME="$CLUSTER_NAME"
export TALOS_CLUSTER_ENDPOINT="$CLUSTER_NAME.$CLUSTER_EXTERNAL_DOMAIN" #Needs to be resolvable
#These are manifests that will be appended to the controlplane.yaml file
export TALOS_APPEND_MANIFESTS_CONTROL_NODES=()

export TALOS_ADDITIONAL_TRUSTEDROOT_FILES=() #Additional trusted root CA certs to add to Talos nodes, relative to overlay dir, example talos/ca.crt

### DISK ENCRYPTION ###

export TALOS_DISK_ENCRYPTION_KMS=true #If true, KMS will be used for disk encryption, TALOS_DISK_ENCRYPTION_KMS_URL must be set if this is true
export TALOS_DISK_ENCRYPTION_KMS_URL="https://kms.yourCluster.dk:50051" #The KMS url to use for encrypting the system disk, make sure TALOS_ADDITIONAL_TRUSTEDROOT_FILES is set if using a custom CA


###############################
#           CILIUM            #
###############################

export CILIUM_HELM_VERSION="1.18.4" #The version of Cilium chart to install
export CILIUM_LB_IP_CIDR="10.32.0.0/16" #The CIDR range to use for LoadBalancer/Ingress services, must not overlap with Pod or Service CIDR, must be routable
###############################
#           TRAEFIK            #
###############################

export TRAEFIK_HELM_VERSION="38.0.1" #The version of Traefik chart to install https://traefik.github.io/charts

###############################
#           Longhorn          #
###############################

export LONGHORN_CHART_VERSION="1.10.1" #The version of Longhorn chart to install https://github.com/longhorn/charts/releases


# https://longhorn.io/docs/1.9.1/snapshots-and-backups/backup-and-restore/set-backup-target/#set-up-smbcifs-backupstore
export LONGHORN_BACKUP_TARGET="cifs://nas.yourcluster.dk/longhorn"
export LONGHORN_BACKUP_TARGET_USERNAME="longhorn"
export LONGHORN_BACKUP_TARGET_PASSWORD="REPLACE_WITH_PASSWORD"

# Verifying backup jobs: Open a volume in Longhorn UI and check the "Recurring Jobs" panel
export LONGHORN_BACKUP_JOB_NAME="daily-backup" #Cron schedule for backups
export LONGHORN_BACKUP_GROUP_NAME="daily-backup" #Volume group name that the backup job will run against, set to default to apply to all
export LONGHORN_BACKUP_CRON_SCHEDULE="0 6 * * *" #Cron schedule for backups, 06:00 every day
export LONGHORN_BACKUP_RETAIN="5" #Number of backups to retain
export LONGHORN_BACKUP_CONCURENCY="2" #Number of concurrent backups to run

###############################
#    CSI SNAPSHOT CONTROLLER  #
###############################

#https://longhorn.io/docs/1.10.1/snapshots-and-backups/csi-snapshot-support/enable-csi-snapshot-support/
export CSI_SNAPSHOT_BRANCH="release-8.4" #The branch of the snapshot controller to use



###############################
#         CERT-MANAGER        #
###############################

export CERT_MGR_HELM_VERSION="v1.19.2" # https://cert-manager.io/docs/installation/helm/
export CERT_MGR_NAMESPACE="cert-manager"


#https://cert-manager.io/docs/usage/csi-driver/
export CERT_MGR_CSI_HELM_VERSION="v0.12.0" #https://quay.io/repository/jetstack/charts/cert-manager-csi-driver?tab=tags&tag=latest
export CERT_MGR_CSI_DEFAULT_SET_VALUES="--set metrics.enabled=false --set priorityClassName=system-cluster-critical" #Default values to set when installing the chart
export CERT_MGR_CSI_SET_VALUES="$CERT_MGR_CSI_DEFAULT_SET_VALUES"
export CERT_MGR_CSI_NAMESPACE="$CERT_MGR_NAMESPACE-csi"


export CERT_MGR_TRUST_NAMESPACE="$CERT_MGR_NAMESPACE" #The namespace where trust-manager will be installed
export CERT_MGR_TRUST_HELM_VERSION="v0.20.3" #https://quay.io/repository/jetstack/charts/trust-manager?tab=tags&tag=latest

###############################
#         GITEA               #
###############################

export GITEA_NAMESPACE="gitea" #The namespace to install Gitea into
export GITEA_PSQL_SIZE="15Gi" #Size of the Postgresql DB volume
export GITEA_PSQL_VERSION="16.11" #Version of Postgresql to use for Gitea
export GITEA_PSQL_USERNAME="gitea-sql-user" #Username for the Gitea database user


export GITEA_HELM_VERSION="10.1.3" #The version of Gitea chart to install https://artifacthub.io/packages/helm/gitea-charts/gitea
export GITEA_IMAGE_TAG="1.25.4" #The version of Gitea to install https://hub.docker.com/r/gitea/gitea
export GITEA_DOMAIN_NAME="gitea.${CLUSTER_EXTERNAL_DOMAIN}" #The domain to access Gitea on
export GITEA_SHARED_STORAGE_SIZE="35Gi" #Size of the shared storage volume

#Gitea organization and repo names where this repo will be cloned to
export GITEA_CLUSTER_GITEA_ORG_NAME="${CLUSTER_NAME}-cluster" #The name of the Gitea organization to host the cluster repos
export GITEA_CLUSTER_SERVICES_REPO_NAME="cluster-services" #The name of the cluster services repo in Gitea
export GITEA_CLUSTER_SERVICES_REPO_BRANCH="main" #The branch to use for the cluster services repo
export GITEA_CLUSTER_SERVICES_REPO_URL="https://${GITEA_DOMAIN_NAME}/${GITEA_CLUSTER_GITEA_ORG_NAME}/${GITEA_CLUSTER_SERVICES_REPO_NAME}.git"

###############################
#         GITEA  Runners      #
###############################


export GITEA_RUNNERS_IMAGE_TAG="0.2.13-dind-rootless" #The version of Gitea Runners to install, https://hub.docker.com/r/gitea/act_runner/tags

###############################
#         ArgoCD              #
###############################
export ARGOCD_DOMAIN="argocd.${CLUSTER_EXTERNAL_DOMAIN}" #The domain to access ArgoCD on
export ARGOCD_NAMESPACE="argocd" #The namespace to install ArgoCD into
export ARGOCD_HELM_VERSION="9.3.4" #The version of ArgoCD chart to install
export ARGOCD_IMAGE_TAG="v3.3.0" #The version of ArgoCD to install https://github.com/argoproj/argo-cd/releases


###############################
#         CNPG               #
###############################
export CNPG_HELM_VERSION="0.27.0" #The version of CNPG chart to install

###############################
#   Metrics-server            #
###############################
export METRICS_SERVER_HELM_VERSION="3.13.0" #The version of metrics-server chart to install https://artifacthub.io/packages/helm/metrics-server/metrics-server

###############################
#      External-DNS           #
###############################
#https://github.com/kubernetes-sigs/external-dns/issues/3721
#https://github.com/opnsense/plugins/pull/4177
export EXTERNAL_DNS_HELM_VERSION="1.20.0" #The version of external-dns chart to install https://artifacthub.io/packages/helm/external-dns/external-dns
export EXTERNAL_DNS_BINDSERVER_IP="192.168.0.1" #The IP address of OPNsense running BIND
export EXTERNAL_DNS_TSIG_KEYNAME="SOME_KEY_NAME" #The name of the TSIG key in BIND
export EXTERNAL_DNS_TSIG_SECRET="SECRET" #The base64 encoded TSIG secret
export EXTERNAL_DNS_TSIG_ALGORITHM="hmac-sha256" #The TSIG algorithm (hmac-sha256, hmac-sha512, etc)
export EXTERNAL_DNS_DOMAIN_FILTERS="${CLUSTER_EXTERNAL_DOMAIN}" #The domain filters to use for external-dns, only manage records for these domains. For now only works with a single domain. Add an value files to overlay to support multiple domains.



###############################
#      Reloader          #
###############################
#https://github.com/stakater/Reloader?tab=readme-ov-file#-installation

export RELOADER_HELM_VERSION="2.2.4" #The version of reloader chart to install https://github.com/stakater/Reloader/releases
export RELOADER_NAMESPACE="reloader" #The namespace to install reloader into
###############################



